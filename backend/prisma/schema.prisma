generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String           @id @default(uuid())
  name          String
  email         String           @unique
  phone         String?
  password      String
  role          Role             @default(USER)
  latitude      Float?
  longitude     Float?
  address       String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  chatSessions  ChatSession[]
  ratingsGiven  Rating[]         @relation("RatingsGiven")
  requests      ServiceRequest[] @relation("UserRequests")
  workerProfile WorkerProfile?
}

model WorkerProfile {
  id              String           @id @default(uuid())
  userId          String           @unique
  serviceType     ServiceType
  isAvailable     Boolean          @default(true)
  latitude        Float?
  longitude       Float?
  address         String?
  rating          Float            @default(0)
  totalJobs       Int              @default(0)
  bio             String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  ratingsReceived Rating[]         @relation("RatingsReceived")
  requests        ServiceRequest[] @relation("WorkerRequests")
  user            User             @relation(fields: [userId], references: [id])
}

model ChatSession {
  id        String          @id @default(uuid())
  userId    String
  state     ChatState       @default(INIT)
  context   Json            @default("{}")
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  messages  ChatMessage[]
  user      User            @relation(fields: [userId], references: [id])
  request   ServiceRequest?
}

model ChatMessage {
  id        String      @id @default(uuid())
  sessionId String
  role      String
  content   String
  metadata  Json?
  createdAt DateTime    @default(now())
  session   ChatSession @relation(fields: [sessionId], references: [id])
}

model ServiceRequest {
  id            String         @id @default(uuid())
  sessionId     String?        @unique
  userId        String
  workerId      String?
  serviceType   ServiceType
  description   String
  status        RequestStatus  @default(PENDING)
  userLatitude  Float?
  userLongitude Float?
  userAddress   String?
  proposedPrice Float?
  finalPrice    Float?
  userApproved  Boolean        @default(false)
  workerNotes   String?
  scheduledAt   DateTime?
  acceptedAt    DateTime?
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  payment       Payment?
  rating        Rating?
  session       ChatSession?   @relation(fields: [sessionId], references: [id])
  user          User           @relation("UserRequests", fields: [userId], references: [id])
  worker        WorkerProfile? @relation("WorkerRequests", fields: [workerId], references: [id])
}

model Payment {
  id                String         @id @default(uuid())
  requestId         String         @unique
  razorpayOrderId   String?        @unique
  razorpayPaymentId String?
  razorpaySignature String?
  amount            Float
  currency          String         @default("INR")
  status            PaymentStatus  @default(PENDING)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  request           ServiceRequest @relation(fields: [requestId], references: [id])
}

model Rating {
  id        String         @id @default(uuid())
  requestId String         @unique
  raterId   String
  workerId  String
  score     Int
  comment   String?
  createdAt DateTime       @default(now())
  rater     User           @relation("RatingsGiven", fields: [raterId], references: [id])
  request   ServiceRequest @relation(fields: [requestId], references: [id])
  worker    WorkerProfile  @relation("RatingsReceived", fields: [workerId], references: [id])
}

enum Role {
  USER
  WORKER
  ADMIN
}

enum ServiceType {
  PLUMBER
  ELECTRICIAN
  AC_TECHNICIAN
  CARPENTER
}

enum RequestStatus {
  PENDING
  SEARCHING
  ASSIGNED
  ACCEPTED
  IN_PROGRESS
  PRICE_SET
  AWAITING_APPROVAL
  PAYMENT_PENDING
  PAID
  COMPLETED
  CANCELLED
  REJECTED
}

enum ChatState {
  INIT
  ISSUE_CAPTURED
  NEED_LOCATION
  SEARCHING
  ASSIGNED
  AWAITING_PRICE
  PAYMENT_PENDING
  COMPLETED
}

enum PaymentStatus {
  PENDING
  CREATED
  PAID
  FAILED
  REFUNDED
}
